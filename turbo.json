{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "compile": {
      "outputs": ["artifacts/**", "cache/**", "types/**"]
    },
    "deploy": {
      "dependsOn": ["compile"],
      "outputs": [],
      "cache": false
    },
    "node": {
      "cache": false,
      "persistent": true
    }
  }
}
