{
  "name": "mintd",
  "version": "1.0.0",
  "description": "Mintd — Web3 platform for luxury watch owners to verify ownership and mint verifiable ERC-721 digital certificates on Polygon.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "contracts:node": "turbo run node --filter=@mintd/contracts",
    "contracts:compile": "turbo run compile --filter=@mintd/contracts",
    "contracts:deploy": "turbo run deploy --filter=@mintd/contracts",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "keywords": [],
  "author": "Chidube Anike",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.2",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0"
  }
}
